---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const siteUrl = 'https://ai-tools-hub.netlify.app';
const fullTitle = `${title} | AI Tools Hub - Free Online AI Tools`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical || Astro.url.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900">
    <!-- Header -->
    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-indigo-600 hover:text-indigo-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 1 4 4v2a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z"/><path d="M16 14a4 4 0 0 1 4 4v2H4v-2a4 4 0 0 1 4-4h8z"/><circle cx="12" cy="6" r="1"/></svg>
          AI Tools Hub
        </a>
        <nav class="hidden md:flex gap-6 text-sm">
          <a href="/" class="hover:text-indigo-600">Home</a>
          <a href="/tools/summarizer" class="hover:text-indigo-600">Summarizer</a>
          <a href="/tools/sentiment" class="hover:text-indigo-600">Sentiment</a>
          <a href="/tools/translator" class="hover:text-indigo-600">Translator</a>
          <a href="/tools/word-counter" class="hover:text-indigo-600">Word Counter</a>
          <a href="/tools/text-converter" class="hover:text-indigo-600">Text Converter</a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-gray-300 mt-16">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <div class="grid md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-white font-semibold mb-3">AI Tools Hub</h3>
            <p class="text-sm">Free AI-powered tools that run entirely in your browser. No data sent to servers. No API keys needed. 100% private.</p>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-3">AI Tools</h3>
            <ul class="text-sm space-y-2">
              <li><a href="/tools/summarizer" class="hover:text-white">AI Text Summarizer</a></li>
              <li><a href="/tools/sentiment" class="hover:text-white">AI Sentiment Analyzer</a></li>
              <li><a href="/tools/translator" class="hover:text-white">AI Translator</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-3">Text Tools</h3>
            <ul class="text-sm space-y-2">
              <li><a href="/tools/word-counter" class="hover:text-white">Word & Character Counter</a></li>
              <li><a href="/tools/text-converter" class="hover:text-white">Text Case Converter</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-700 mt-8 pt-8 text-center text-sm">
          <p>&copy; {new Date().getFullYear()} AI Tools Hub. All tools run locally in your browser.</p>
          <!-- Ad placeholder -->
          <div id="ad-footer" class="mt-4"></div>
        </div>
      </div>
    </footer>
  </body>
</html>
