---
import '../styles/global.css';
import { config } from '../config';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const siteUrl = config.siteUrl;
const fullTitle = `${title} | AI Tools Hub - Free Online AI Tools`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical || Astro.url.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {config.adsenseId && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${config.adsenseId}`}
        crossorigin="anonymous"
      />
    )}

    <!-- GoatCounter Analytics (free, privacy-friendly, no cookies) -->
    <script data-goatcounter="https://kuresss-ai-tools.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900">
    <!-- Header -->
    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-xl font-bold text-indigo-600 hover:text-indigo-700">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 1 4 4v2a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z"/><path d="M16 14a4 4 0 0 1 4 4v2H4v-2a4 4 0 0 1 4-4h8z"/><circle cx="12" cy="6" r="1"/></svg>
          AI Tools Hub
        </a>
        <nav class="hidden md:flex gap-5 text-sm">
          <a href="/" class="hover:text-indigo-600">Home</a>
          <a href="/tools/summarizer" class="hover:text-indigo-600">Summarizer</a>
          <a href="/tools/sentiment" class="hover:text-indigo-600">Sentiment</a>
          <a href="/tools/translator" class="hover:text-indigo-600">Translator</a>
          <a href="/tools/word-counter" class="hover:text-indigo-600">Word Counter</a>
          <a href="/tools/json-formatter" class="hover:text-indigo-600">JSON</a>
          <a href="/tools/base64" class="hover:text-indigo-600">Base64</a>
        </nav>
      </div>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-gray-300 mt-16">
      <div class="max-w-6xl mx-auto px-4 py-12">
        <div class="grid md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-white font-semibold mb-3">AI Tools Hub</h3>
            <p class="text-sm">Free AI-powered tools that run entirely in your browser. No data sent to servers. No API keys needed. 100% private.</p>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-3">AI Tools</h3>
            <ul class="text-sm space-y-2">
              <li><a href="/tools/summarizer" class="hover:text-white">AI Text Summarizer</a></li>
              <li><a href="/tools/sentiment" class="hover:text-white">AI Sentiment Analyzer</a></li>
              <li><a href="/tools/translator" class="hover:text-white">AI Translator</a></li>
            </ul>
          </div>
          <div>
            <h3 class="text-white font-semibold mb-3">Text & Dev Tools</h3>
            <ul class="text-sm space-y-2">
              <li><a href="/tools/word-counter" class="hover:text-white">Word & Character Counter</a></li>
              <li><a href="/tools/text-converter" class="hover:text-white">Text Case Converter</a></li>
              <li><a href="/tools/json-formatter" class="hover:text-white">JSON Formatter</a></li>
              <li><a href="/tools/base64" class="hover:text-white">Base64 Encoder/Decoder</a></li>
              <li><a href="/tools/lorem-generator" class="hover:text-white">Lorem Ipsum Generator</a></li>
              <li><a href="/tools/hash-generator" class="hover:text-white">Hash Generator</a></li>
              <li><a href="/tools/url-encoder" class="hover:text-white">URL Encoder/Decoder</a></li>
              <li><a href="/tools/regex-tester" class="hover:text-white">Regex Tester</a></li>
              <li><a href="/tools/color-converter" class="hover:text-white">Color Converter</a></li>
              <li><a href="/tools/markdown-preview" class="hover:text-white">Markdown Preview</a></li>
              <li><a href="/tools/diff-checker" class="hover:text-white">Diff Checker</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-gray-700 mt-8 pt-8 text-center text-sm">
          <p>&copy; {new Date().getFullYear()} AI Tools Hub. All tools run locally in your browser.</p>
          <div class="mt-4 flex justify-center gap-4">
            {config.kofiUsername && (
              <a href={`https://ko-fi.com/${config.kofiUsername}`} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-[#13C3FF] text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90 transition-opacity">
                Support on Ko-fi
              </a>
            )}
            {config.bmcUsername && (
              <a href={`https://buymeacoffee.com/${config.bmcUsername}`} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-[#FFDD00] text-gray-900 px-4 py-2 rounded-lg text-sm font-medium hover:opacity-90 transition-opacity">
                Buy Me a Coffee
              </a>
            )}
          </div>
          <!-- Ad placeholder -->
          <div id="ad-footer" class="mt-4"></div>
        </div>
      </div>
    </footer>
  </body>
</html>
