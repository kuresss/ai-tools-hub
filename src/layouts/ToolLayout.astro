---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  isAI?: boolean;
}

const { title, description, isAI = false } = Astro.props;
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": title,
  "description": description,
  "url": Astro.url.href,
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "browserRequirements": "Requires a modern web browser with JavaScript enabled"
});

import { config } from '../config';
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={jsonLd} />
  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-indigo-600">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{title}</span>
    </nav>

    <!-- Tool Header -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <h1 class="text-3xl font-bold">{title}</h1>
        {isAI && (
          <span class="bg-indigo-100 text-indigo-700 text-xs font-semibold px-2 py-1 rounded-full">
            AI-Powered
          </span>
        )}
      </div>
      <p class="text-gray-600">{description}</p>
      {isAI && (
        <p class="text-sm text-green-600 mt-2 flex items-center gap-1">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/></svg>
          Runs 100% in your browser. Your data never leaves your device.
        </p>
      )}
    </div>

    <!-- A-Ads Banner -->
    <div id="ad-tool-top" class="mb-6 text-center">
      <!-- BEGIN AADS AD UNIT 2432570 -->
      <div id="frame" style="width: 100%;margin: auto;position: relative; z-index: 99998;">
        <iframe data-aa='2432570' src='//acceptable.a-ads.com/2432570?partial=1' style='border:0px; padding:0; width:100%; height:auto; overflow:hidden; background-color: transparent;'></iframe>
      </div>
      <!-- END AADS AD UNIT 2432570 -->
    </div>

    <!-- Tool Content -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <slot />
    </div>

    <!-- Support CTA - shown after tool result -->
    {config.kofiUsername && (
      <div class="mt-6 bg-gradient-to-r from-indigo-50 to-purple-50 border border-indigo-100 rounded-xl p-5 text-center">
        <p class="text-gray-700 mb-3 text-sm">Found this tool helpful? Support free tools for everyone.</p>
        <a href={`https://ko-fi.com/${config.kofiUsername}`} target="_blank" rel="noopener"
          class="inline-flex items-center gap-2 bg-[#13C3FF] text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:opacity-90 transition-opacity">
          Support on Ko-fi
        </a>
      </div>
    )}

    <!-- Ad placeholder -->
    <div id="ad-tool-bottom" class="mt-6 text-center">
      <!-- AdSense -->
    </div>
  </div>

    <!-- Related Tools -->
    <div class="mt-12 max-w-4xl mx-auto px-4">
      <h2 class="text-xl font-bold mb-6">More Free Tools</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <a href="/tools/summarizer" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">AI Summarizer</a>
        <a href="/tools/sentiment" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">Sentiment Analyzer</a>
        <a href="/tools/translator" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">AI Translator</a>
        <a href="/tools/word-counter" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">Word Counter</a>
        <a href="/tools/json-formatter" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">JSON Formatter</a>
        <a href="/tools/base64" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">Base64 Encoder</a>
        <a href="/tools/hash-generator" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">Hash Generator</a>
        <a href="/tools/url-encoder" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">URL Encoder</a>
        <a href="/tools/regex-tester" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">Regex Tester</a>
        <a href="/tools/color-converter" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">Color Converter</a>
        <a href="/tools/markdown-preview" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">Markdown Preview</a>
        <a href="/tools/diff-checker" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">Diff Checker</a>
        <a href="/tools/qr-generator" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">QR Code Generator</a>
        <a href="/tools/password-generator" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">Password Generator</a>
        <a href="/tools/text-to-speech" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">Text to Speech</a>
        <a href="/tools/image-compressor" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">Image Compressor</a>
        <a href="/tools/timestamp-converter" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">Timestamp Converter</a>
        <a href="/tools/cron-generator" class="bg-white border border-gray-200 rounded-lg p-3 text-center hover:border-indigo-300 transition-colors text-sm">Cron Generator</a>
      </div>
    </div>
</BaseLayout>
