---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="AI Text Summarizer"
  description="Summarize long articles, papers, and documents instantly using AI. Runs 100% in your browser - no API keys, no sign-up, completely free and private."
  isAI={true}
>
  <div id="summarizer-app">
    <div id="model-status" class="mb-4 p-3 bg-yellow-50 border border-yellow-200 rounded-lg text-sm text-yellow-700">
      Click "Summarize" to load the AI model (first time may take 30-60 seconds to download).
    </div>

    <textarea
      id="sum-input"
      rows="10"
      placeholder="Paste the article or text you want to summarize here... (minimum 50 characters)"
      class="w-full border border-gray-300 rounded-lg p-4 text-base resize-y focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
    ></textarea>

    <div class="flex items-center gap-4 mt-4">
      <button id="sum-run" class="bg-indigo-600 text-white px-6 py-2.5 rounded-lg text-sm font-medium hover:bg-indigo-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
        Summarize
      </button>
      <button id="sum-clear" class="bg-gray-200 text-gray-700 px-4 py-2.5 rounded-lg text-sm hover:bg-gray-300 transition-colors">
        Clear
      </button>
      <div id="sum-spinner" class="hidden">
        <svg class="animate-spin h-5 w-5 text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      </div>
    </div>

    <div id="sum-result-container" class="mt-6 hidden">
      <label class="block text-sm font-medium text-gray-700 mb-2">Summary</label>
      <div id="sum-output" class="border border-gray-300 rounded-lg p-4 bg-gray-50 min-h-[100px] whitespace-pre-wrap"></div>
      <button id="sum-copy" class="mt-3 bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-indigo-700 transition-colors">
        Copy Summary
      </button>
    </div>
  </div>

  <!-- SEO Content -->
  <div class="mt-12 prose prose-sm max-w-none">
    <h2>Free AI Text Summarizer Online</h2>
    <p>Summarize long articles, research papers, blog posts, and documents instantly using AI. Our summarizer uses advanced machine learning models that run directly in your browser - no data is ever sent to external servers.</p>

    <h3>How does the AI Summarizer work?</h3>
    <p>This tool uses the Transformers.js library to run a pre-trained summarization model (distilbart-cnn-6-6) directly in your web browser. The model is downloaded once and cached for future use. All text processing happens locally on your device.</p>

    <h3>Key Features</h3>
    <ul>
      <li><strong>100% Private</strong> - Your text never leaves your browser</li>
      <li><strong>No API Key Required</strong> - Unlike ChatGPT or other AI services</li>
      <li><strong>Unlimited Use</strong> - No daily limits or usage caps</li>
      <li><strong>Works Offline</strong> - After the first model download</li>
      <li><strong>Free Forever</strong> - No hidden costs or premium tiers</li>
    </ul>

    <h3>Best Use Cases</h3>
    <ul>
      <li>Summarizing research papers and academic articles</li>
      <li>Getting the gist of long news articles</li>
      <li>Creating brief overviews of reports and documents</li>
      <li>Condensing meeting notes and emails</li>
    </ul>
  </div>
</ToolLayout>

<script type="module">
  import { pipeline } from 'https://cdn.jsdelivr.net/npm/@huggingface/transformers@3.5.1';

  let summarizer = null;
  const statusEl = document.getElementById('model-status');
  const inputEl = document.getElementById('sum-input');
  const outputEl = document.getElementById('sum-output');
  const runBtn = document.getElementById('sum-run');
  const spinner = document.getElementById('sum-spinner');
  const resultContainer = document.getElementById('sum-result-container');

  async function loadModel() {
    statusEl.className = 'mb-4 p-3 bg-blue-50 border border-blue-200 rounded-lg text-sm text-blue-700';
    statusEl.textContent = 'Loading AI model... This may take 30-60 seconds on first use.';
    runBtn.disabled = true;
    spinner.classList.remove('hidden');

    try {
      summarizer = await pipeline('summarization', 'Xenova/distilbart-cnn-6-6', {
        dtype: 'q8',
      });
      statusEl.className = 'mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700';
      statusEl.textContent = 'AI model loaded! Ready to summarize.';
    } catch (err) {
      statusEl.className = 'mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700';
      statusEl.textContent = 'Failed to load model: ' + err.message;
    } finally {
      runBtn.disabled = false;
      spinner.classList.add('hidden');
    }
  }

  runBtn.addEventListener('click', async () => {
    const text = inputEl.value.trim();
    if (text.length < 50) {
      alert('Please enter at least 50 characters to summarize.');
      return;
    }

    if (!summarizer) {
      await loadModel();
      if (!summarizer) return;
    }

    runBtn.disabled = true;
    spinner.classList.remove('hidden');
    statusEl.className = 'mb-4 p-3 bg-blue-50 border border-blue-200 rounded-lg text-sm text-blue-700';
    statusEl.textContent = 'Summarizing... This may take a moment.';

    try {
      const result = await summarizer(text.slice(0, 3000), {
        max_new_tokens: 150,
        min_new_tokens: 30,
      });
      outputEl.textContent = result[0].summary_text;
      resultContainer.classList.remove('hidden');
      statusEl.className = 'mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-sm text-green-700';
      statusEl.textContent = 'Done! Summary generated successfully.';
    } catch (err) {
      statusEl.className = 'mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700';
      statusEl.textContent = 'Error: ' + err.message;
    } finally {
      runBtn.disabled = false;
      spinner.classList.add('hidden');
    }
  });

  document.getElementById('sum-copy').addEventListener('click', () => {
    navigator.clipboard.writeText(outputEl.textContent);
  });

  document.getElementById('sum-clear').addEventListener('click', () => {
    inputEl.value = '';
    outputEl.textContent = '';
    resultContainer.classList.add('hidden');
  });
</script>
