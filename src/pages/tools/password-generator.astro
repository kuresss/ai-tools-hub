---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Password Generator"
  description="Generate strong, random passwords with customizable options. Choose length, character types, and generate multiple passwords at once."
>
  <div id="pw-app">
    <div class="space-y-4">
      <div>
        <label for="pw-length" class="block text-sm font-medium text-gray-700 mb-1">
          Password Length: <span id="pw-length-val">16</span>
        </label>
        <input type="range" id="pw-length" min="8" max="128" value="16" class="w-full accent-indigo-600" />
        <div class="flex justify-between text-xs text-gray-400">
          <span>8</span>
          <span>128</span>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <label class="flex items-center gap-2 text-sm">
          <input type="checkbox" id="pw-upper" checked class="accent-indigo-600" />
          Uppercase (A-Z)
        </label>
        <label class="flex items-center gap-2 text-sm">
          <input type="checkbox" id="pw-lower" checked class="accent-indigo-600" />
          Lowercase (a-z)
        </label>
        <label class="flex items-center gap-2 text-sm">
          <input type="checkbox" id="pw-numbers" checked class="accent-indigo-600" />
          Numbers (0-9)
        </label>
        <label class="flex items-center gap-2 text-sm">
          <input type="checkbox" id="pw-symbols" checked class="accent-indigo-600" />
          Symbols (!@#$...)
        </label>
      </div>

      <div>
        <label for="pw-count" class="block text-sm font-medium text-gray-700 mb-1">Number of Passwords</label>
        <select id="pw-count" class="border border-gray-300 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-indigo-500">
          <option value="1" selected>1</option>
          <option value="2">2</option>
          <option value="3">3</option>
          <option value="4">4</option>
          <option value="5">5</option>
        </select>
      </div>

      <button id="pw-generate" class="bg-indigo-600 text-white px-6 py-2 rounded-lg text-sm hover:bg-indigo-700 transition-colors">
        Generate Password
      </button>
    </div>

    <div id="pw-results" class="mt-6 space-y-3"></div>
  </div>

  <!-- SEO Content -->
  <div class="mt-12 prose prose-sm max-w-none">
    <h2>Free Random Password Generator</h2>
    <p>Create strong, secure passwords instantly with our free password generator. Customize length, include uppercase, lowercase, numbers, and symbols to meet any security requirement. Generate up to 5 passwords at once.</p>

    <h3>Features</h3>
    <ul>
      <li><strong>Customizable length</strong> - Generate passwords from 8 to 128 characters</li>
      <li><strong>Character options</strong> - Include or exclude uppercase, lowercase, numbers, and symbols</li>
      <li><strong>Strength meter</strong> - Visual indicator of password strength</li>
      <li><strong>Batch generation</strong> - Generate up to 5 passwords at once</li>
      <li><strong>One-click copy</strong> - Easily copy passwords to clipboard</li>
    </ul>

    <h3>Tips for Strong Passwords</h3>
    <ul>
      <li>Use at least 12 characters for strong security</li>
      <li>Include a mix of uppercase, lowercase, numbers, and symbols</li>
      <li>Never reuse passwords across different accounts</li>
      <li>Consider using a password manager to store your passwords</li>
    </ul>
  </div>

  <!-- How to Use Section -->
  <div class="mt-12">
    <h2 class="text-2xl font-bold mb-4">How to Use the Password Generator</h2>
    <ol class="list-decimal pl-6 space-y-3 text-gray-600">
      <li><strong>Set the password length</strong> — Use the slider to choose a length between 8 and 128 characters. A minimum of 12 characters is recommended for strong security.</li>
      <li><strong>Select character types</strong> — Check or uncheck uppercase letters, lowercase letters, numbers, and symbols to match the requirements of the service you are signing up for.</li>
      <li><strong>Choose the quantity</strong> — Select how many passwords you want to generate at once, from 1 to 5.</li>
      <li><strong>Generate and review</strong> — Click "Generate Password" and review the results along with the strength meter for each password.</li>
      <li><strong>Copy to clipboard</strong> — Click the "Copy" button next to any password to copy it and paste it wherever you need it.</li>
    </ol>
  </div>

  <!-- FAQ Section -->
  <div class="mt-12 space-y-6">
    <h2 class="text-2xl font-bold">Frequently Asked Questions</h2>
    <details class="border border-gray-200 rounded-lg p-4">
      <summary class="font-semibold cursor-pointer">How long should my password be?</summary>
      <p class="mt-3 text-gray-600 text-sm">Security experts recommend using passwords that are at least 12 to 16 characters long. Longer passwords are exponentially harder to crack through brute-force attacks. For high-security accounts like banking or email, consider using 20 or more characters.</p>
    </details>
    <details class="border border-gray-200 rounded-lg p-4">
      <summary class="font-semibold cursor-pointer">Are the generated passwords truly random?</summary>
      <p class="mt-3 text-gray-600 text-sm">Yes. This tool uses the Web Crypto API (crypto.getRandomValues) built into your browser, which provides cryptographically secure random number generation. This is the same standard used by professional security applications.</p>
    </details>
    <details class="border border-gray-200 rounded-lg p-4">
      <summary class="font-semibold cursor-pointer">Can you see or store my generated passwords?</summary>
      <p class="mt-3 text-gray-600 text-sm">No. All password generation happens entirely in your browser. No passwords are ever transmitted to or stored on any server. Once you close or refresh the page, the generated passwords are gone unless you saved them.</p>
    </details>
    <details class="border border-gray-200 rounded-lg p-4">
      <summary class="font-semibold cursor-pointer">Should I use symbols in my password?</summary>
      <p class="mt-3 text-gray-600 text-sm">Including symbols significantly increases password strength by expanding the character set an attacker would need to guess. However, some websites restrict which special characters are allowed. If a service rejects your password, try regenerating without symbols.</p>
    </details>
    <details class="border border-gray-200 rounded-lg p-4">
      <summary class="font-semibold cursor-pointer">How do I remember strong random passwords?</summary>
      <p class="mt-3 text-gray-600 text-sm">You are not expected to memorize random passwords. Use a dedicated password manager such as Bitwarden, 1Password, or KeePass to securely store all your passwords. This way you only need to remember one strong master password.</p>
    </details>
  </div>
</ToolLayout>

<script>
  const lengthSlider = document.getElementById('pw-length') as HTMLInputElement;
  const lengthVal = document.getElementById('pw-length-val')!;
  const upperCheck = document.getElementById('pw-upper') as HTMLInputElement;
  const lowerCheck = document.getElementById('pw-lower') as HTMLInputElement;
  const numbersCheck = document.getElementById('pw-numbers') as HTMLInputElement;
  const symbolsCheck = document.getElementById('pw-symbols') as HTMLInputElement;
  const countSelect = document.getElementById('pw-count') as HTMLSelectElement;
  const generateBtn = document.getElementById('pw-generate')!;
  const resultsDiv = document.getElementById('pw-results')!;

  const UPPER = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  const LOWER = 'abcdefghijklmnopqrstuvwxyz';
  const NUMBERS = '0123456789';
  const SYMBOLS = '!@#$%^&*()_+-=[]{}|;:,.<>?';

  lengthSlider.addEventListener('input', () => {
    lengthVal.textContent = lengthSlider.value;
  });

  function generatePassword(length: number): string {
    let chars = '';
    if (upperCheck.checked) chars += UPPER;
    if (lowerCheck.checked) chars += LOWER;
    if (numbersCheck.checked) chars += NUMBERS;
    if (symbolsCheck.checked) chars += SYMBOLS;

    if (!chars) {
      chars = LOWER;
      lowerCheck.checked = true;
    }

    const array = new Uint32Array(length);
    crypto.getRandomValues(array);
    return Array.from(array, v => chars[v % chars.length]).join('');
  }

  function getStrength(pw: string): { label: string; color: string; width: string } {
    let score = 0;
    if (pw.length >= 12) score++;
    if (pw.length >= 16) score++;
    if (/[A-Z]/.test(pw)) score++;
    if (/[a-z]/.test(pw)) score++;
    if (/[0-9]/.test(pw)) score++;
    if (/[^A-Za-z0-9]/.test(pw)) score++;

    if (score <= 2) return { label: 'Weak', color: 'bg-red-500', width: 'w-1/4' };
    if (score <= 3) return { label: 'Medium', color: 'bg-yellow-500', width: 'w-2/4' };
    if (score <= 4) return { label: 'Strong', color: 'bg-green-500', width: 'w-3/4' };
    return { label: 'Very Strong', color: 'bg-green-700', width: 'w-full' };
  }

  function generate() {
    const length = parseInt(lengthSlider.value);
    const count = parseInt(countSelect.value);
    resultsDiv.innerHTML = '';

    for (let i = 0; i < count; i++) {
      const pw = generatePassword(length);
      const strength = getStrength(pw);

      const div = document.createElement('div');
      div.className = 'bg-gray-50 rounded-lg p-4';
      div.innerHTML = `
        <div class="flex items-center gap-3">
          <code class="flex-1 text-sm break-all font-mono bg-white border border-gray-200 rounded p-2">${pw}</code>
          <button class="pw-copy bg-indigo-600 text-white px-3 py-1.5 rounded text-sm hover:bg-indigo-700 transition-colors whitespace-nowrap" data-pw="${pw}">Copy</button>
        </div>
        <div class="mt-2 flex items-center gap-2">
          <div class="flex-1 bg-gray-200 rounded-full h-2">
            <div class="${strength.color} ${strength.width} h-2 rounded-full transition-all"></div>
          </div>
          <span class="text-xs text-gray-600 whitespace-nowrap">${strength.label}</span>
        </div>
      `;
      resultsDiv.appendChild(div);
    }

    resultsDiv.querySelectorAll('.pw-copy').forEach(btn => {
      btn.addEventListener('click', () => {
        const pw = (btn as HTMLElement).dataset.pw!;
        navigator.clipboard.writeText(pw);
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
      });
    });
  }

  generateBtn.addEventListener('click', generate);
  generate();
</script>
