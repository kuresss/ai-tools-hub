---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Text Case Converter"
  description="Convert text to UPPERCASE, lowercase, Title Case, Sentence case, camelCase, snake_case, kebab-case, and more. Free online tool."
>
  <div id="text-converter-app">
    <textarea
      id="tc-input"
      rows="6"
      placeholder="Type or paste your text here..."
      class="w-full border border-gray-300 rounded-lg p-4 text-base resize-y focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
    ></textarea>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mt-4">
      <button data-case="upper" class="tc-btn bg-gray-100 hover:bg-indigo-100 text-gray-700 hover:text-indigo-700 px-4 py-3 rounded-lg text-sm font-medium transition-colors">
        UPPERCASE
      </button>
      <button data-case="lower" class="tc-btn bg-gray-100 hover:bg-indigo-100 text-gray-700 hover:text-indigo-700 px-4 py-3 rounded-lg text-sm font-medium transition-colors">
        lowercase
      </button>
      <button data-case="title" class="tc-btn bg-gray-100 hover:bg-indigo-100 text-gray-700 hover:text-indigo-700 px-4 py-3 rounded-lg text-sm font-medium transition-colors">
        Title Case
      </button>
      <button data-case="sentence" class="tc-btn bg-gray-100 hover:bg-indigo-100 text-gray-700 hover:text-indigo-700 px-4 py-3 rounded-lg text-sm font-medium transition-colors">
        Sentence case
      </button>
      <button data-case="camel" class="tc-btn bg-gray-100 hover:bg-indigo-100 text-gray-700 hover:text-indigo-700 px-4 py-3 rounded-lg text-sm font-medium transition-colors">
        camelCase
      </button>
      <button data-case="pascal" class="tc-btn bg-gray-100 hover:bg-indigo-100 text-gray-700 hover:text-indigo-700 px-4 py-3 rounded-lg text-sm font-medium transition-colors">
        PascalCase
      </button>
      <button data-case="snake" class="tc-btn bg-gray-100 hover:bg-indigo-100 text-gray-700 hover:text-indigo-700 px-4 py-3 rounded-lg text-sm font-medium transition-colors">
        snake_case
      </button>
      <button data-case="kebab" class="tc-btn bg-gray-100 hover:bg-indigo-100 text-gray-700 hover:text-indigo-700 px-4 py-3 rounded-lg text-sm font-medium transition-colors">
        kebab-case
      </button>
      <button data-case="reverse" class="tc-btn bg-gray-100 hover:bg-indigo-100 text-gray-700 hover:text-indigo-700 px-4 py-3 rounded-lg text-sm font-medium transition-colors">
        Reverse
      </button>
      <button data-case="alternating" class="tc-btn bg-gray-100 hover:bg-indigo-100 text-gray-700 hover:text-indigo-700 px-4 py-3 rounded-lg text-sm font-medium transition-colors">
        aLtErNaTiNg
      </button>
      <button data-case="slug" class="tc-btn bg-gray-100 hover:bg-indigo-100 text-gray-700 hover:text-indigo-700 px-4 py-3 rounded-lg text-sm font-medium transition-colors">
        url-slug
      </button>
      <button data-case="dot" class="tc-btn bg-gray-100 hover:bg-indigo-100 text-gray-700 hover:text-indigo-700 px-4 py-3 rounded-lg text-sm font-medium transition-colors">
        dot.case
      </button>
    </div>

    <div class="mt-6">
      <label class="block text-sm font-medium text-gray-700 mb-2">Result</label>
      <textarea
        id="tc-output"
        rows="6"
        readonly
        class="w-full border border-gray-300 rounded-lg p-4 text-base bg-gray-50 resize-y"
      ></textarea>
    </div>

    <div class="mt-4 flex gap-3">
      <button id="tc-copy" class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-indigo-700 transition-colors">
        Copy Result
      </button>
      <button id="tc-clear" class="bg-gray-200 text-gray-700 px-4 py-2 rounded-lg text-sm hover:bg-gray-300 transition-colors">
        Clear
      </button>
    </div>
  </div>

  <!-- SEO Content -->
  <div class="mt-12 prose prose-sm max-w-none">
    <h2>Free Online Text Case Converter</h2>
    <p>Convert your text between different cases instantly. Supports UPPERCASE, lowercase, Title Case, camelCase, snake_case, kebab-case, PascalCase, and more. Perfect for developers, writers, and content creators.</p>

    <h3>Supported Conversions</h3>
    <ul>
      <li><strong>UPPERCASE</strong> - Convert all letters to capital letters</li>
      <li><strong>lowercase</strong> - Convert all letters to small letters</li>
      <li><strong>Title Case</strong> - Capitalize the first letter of each word</li>
      <li><strong>camelCase</strong> - Used in JavaScript variable naming</li>
      <li><strong>snake_case</strong> - Used in Python and database column naming</li>
      <li><strong>kebab-case</strong> - Used in CSS class names and URLs</li>
    </ul>
  </div>
</ToolLayout>

<script>
  const input = document.getElementById('tc-input') as HTMLTextAreaElement;
  const output = document.getElementById('tc-output') as HTMLTextAreaElement;

  function toWords(text: string): string[] {
    return text.replace(/([a-z])([A-Z])/g, '$1 $2')
               .replace(/[_\-\.]+/g, ' ')
               .trim()
               .split(/\s+/)
               .filter(w => w.length > 0);
  }

  const converters: Record<string, (text: string) => string> = {
    upper: (t) => t.toUpperCase(),
    lower: (t) => t.toLowerCase(),
    title: (t) => t.replace(/\w\S*/g, w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()),
    sentence: (t) => t.toLowerCase().replace(/(^\s*|[.!?]\s+)(\w)/g, (_, p, c) => p + c.toUpperCase()),
    camel: (t) => {
      const w = toWords(t);
      return w.map((word, i) => i === 0 ? word.toLowerCase() : word.charAt(0).toUpperCase() + word.slice(1).toLowerCase()).join('');
    },
    pascal: (t) => toWords(t).map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join(''),
    snake: (t) => toWords(t).map(w => w.toLowerCase()).join('_'),
    kebab: (t) => toWords(t).map(w => w.toLowerCase()).join('-'),
    reverse: (t) => t.split('').reverse().join(''),
    alternating: (t) => t.split('').map((c, i) => i % 2 === 0 ? c.toLowerCase() : c.toUpperCase()).join(''),
    slug: (t) => toWords(t).map(w => w.toLowerCase()).join('-').replace(/[^a-z0-9\-]/g, ''),
    dot: (t) => toWords(t).map(w => w.toLowerCase()).join('.'),
  };

  document.querySelectorAll('.tc-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const caseType = (btn as HTMLElement).dataset.case!;
      output.value = converters[caseType](input.value);
    });
  });

  document.getElementById('tc-copy')!.addEventListener('click', () => {
    navigator.clipboard.writeText(output.value);
  });

  document.getElementById('tc-clear')!.addEventListener('click', () => {
    input.value = '';
    output.value = '';
  });
</script>
