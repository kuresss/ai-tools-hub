---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Markdown Preview"
  description="Write and preview Markdown in real-time. Free online Markdown editor with live preview. No sign-up required."
>
  <div id="markdown-preview-app">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Markdown Editor</label>
        <textarea
          id="md-input"
          rows="20"
          class="w-full border border-gray-300 rounded-lg p-4 text-sm font-mono resize-y focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
          placeholder="Type Markdown here..."
        ># Hello Markdown

This is a **bold** and *italic* text example.

## Features

- Real-time preview
- No external libraries
- Runs in your browser

### Code Example

`inline code` works too.

```
function hello() {
  console.log("Hello!");
}
```

> This is a blockquote.

[Visit Example](https://example.com)

---

1. First item
2. Second item
3. Third item</textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Preview</label>
        <div
          id="md-preview"
          class="w-full border border-gray-300 rounded-lg p-4 text-base bg-white min-h-[480px] max-h-[600px] overflow-y-auto prose prose-sm max-w-none"
        ></div>
      </div>
    </div>

    <div class="mt-4 flex gap-3">
      <button id="md-copy-html" class="bg-indigo-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-indigo-700 transition-colors">
        Copy HTML
      </button>
      <button id="md-clear" class="bg-gray-200 text-gray-700 px-4 py-2 rounded-lg text-sm hover:bg-gray-300 transition-colors">
        Clear
      </button>
    </div>
  </div>

  <!-- SEO Content -->
  <div class="mt-12 prose prose-sm max-w-none">
    <h2>Free Online Markdown Preview</h2>
    <p>Write Markdown and see it rendered in real-time. Our Markdown editor provides a live side-by-side preview so you can see exactly how your content will look. Perfect for README files, blog posts, documentation, and note-taking.</p>

    <h3>Supported Syntax</h3>
    <ul>
      <li><strong>Headings</strong> - H1 through H6 with # syntax</li>
      <li><strong>Bold and Italic</strong> - **bold**, *italic*, ***bold italic***</li>
      <li><strong>Lists</strong> - Ordered (1. 2. 3.) and unordered (- or *) lists</li>
      <li><strong>Code</strong> - Inline code with backticks and fenced code blocks</li>
      <li><strong>Links</strong> - [text](url) format</li>
      <li><strong>Blockquotes</strong> - > quoted text</li>
      <li><strong>Horizontal rules</strong> - --- or ***</li>
    </ul>

    <h3>Markdown Editor - How to Use</h3>
    <p>Simply type or paste Markdown content in the left editor pane. The preview on the right updates in real-time. You can copy the generated HTML with one click.</p>
  </div>
</ToolLayout>

<script>
  const mdInput = document.getElementById('md-input') as HTMLTextAreaElement;
  const mdPreview = document.getElementById('md-preview')!;

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function parseInline(text: string): string {
    // Bold + Italic
    text = text.replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>');
    // Bold
    text = text.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
    // Italic
    text = text.replace(/\*(.+?)\*/g, '<em>$1</em>');
    // Inline code
    text = text.replace(/`([^`]+)`/g, '<code class="bg-gray-100 px-1 py-0.5 rounded text-sm font-mono">$1</code>');
    // Links
    text = text.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="text-indigo-600 underline" target="_blank" rel="noopener">$1</a>');
    // Images
    text = text.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" class="max-w-full rounded" />');
    return text;
  }

  function parseMarkdown(md: string): string {
    const lines = md.split('\n');
    let html = '';
    let inCodeBlock = false;
    let codeContent = '';
    let inUl = false;
    let inOl = false;

    function closeList() {
      if (inUl) { html += '</ul>'; inUl = false; }
      if (inOl) { html += '</ol>'; inOl = false; }
    }

    for (let i = 0; i < lines.length; i++) {
      const line = lines[i];

      // Fenced code blocks
      if (line.trim().startsWith('```')) {
        if (inCodeBlock) {
          html += `<pre class="bg-gray-900 text-green-400 rounded-lg p-4 overflow-x-auto text-sm font-mono"><code>${escapeHtml(codeContent.trimEnd())}</code></pre>`;
          codeContent = '';
          inCodeBlock = false;
        } else {
          closeList();
          inCodeBlock = true;
        }
        continue;
      }

      if (inCodeBlock) {
        codeContent += line + '\n';
        continue;
      }

      // Horizontal rule
      if (/^(-{3,}|\*{3,}|_{3,})\s*$/.test(line.trim())) {
        closeList();
        html += '<hr class="my-4 border-gray-300" />';
        continue;
      }

      // Headings
      const headingMatch = line.match(/^(#{1,6})\s+(.+)/);
      if (headingMatch) {
        closeList();
        const level = headingMatch[1].length;
        const sizes = ['', 'text-3xl font-bold', 'text-2xl font-bold', 'text-xl font-semibold', 'text-lg font-semibold', 'text-base font-semibold', 'text-sm font-semibold'];
        html += `<h${level} class="${sizes[level]} mt-4 mb-2">${parseInline(headingMatch[2])}</h${level}>`;
        continue;
      }

      // Blockquote
      if (line.trim().startsWith('> ')) {
        closeList();
        html += `<blockquote class="border-l-4 border-indigo-300 pl-4 py-1 my-2 text-gray-600 italic">${parseInline(line.trim().slice(2))}</blockquote>`;
        continue;
      }

      // Unordered list
      const ulMatch = line.match(/^(\s*)[*\-+]\s+(.+)/);
      if (ulMatch) {
        if (inOl) { html += '</ol>'; inOl = false; }
        if (!inUl) { html += '<ul class="list-disc pl-6 my-2 space-y-1">'; inUl = true; }
        html += `<li>${parseInline(ulMatch[2])}</li>`;
        continue;
      }

      // Ordered list
      const olMatch = line.match(/^(\s*)\d+\.\s+(.+)/);
      if (olMatch) {
        if (inUl) { html += '</ul>'; inUl = false; }
        if (!inOl) { html += '<ol class="list-decimal pl-6 my-2 space-y-1">'; inOl = true; }
        html += `<li>${parseInline(olMatch[2])}</li>`;
        continue;
      }

      // Close lists if non-list line
      closeList();

      // Empty line
      if (line.trim() === '') {
        continue;
      }

      // Paragraph
      html += `<p class="my-2">${parseInline(line)}</p>`;
    }

    closeList();
    if (inCodeBlock) {
      html += `<pre class="bg-gray-900 text-green-400 rounded-lg p-4 overflow-x-auto text-sm font-mono"><code>${escapeHtml(codeContent.trimEnd())}</code></pre>`;
    }

    return html;
  }

  let generatedHtml = '';

  function update() {
    generatedHtml = parseMarkdown(mdInput.value);
    mdPreview.innerHTML = generatedHtml;
  }

  mdInput.addEventListener('input', update);

  document.getElementById('md-copy-html')!.addEventListener('click', () => {
    navigator.clipboard.writeText(generatedHtml);
  });

  document.getElementById('md-clear')!.addEventListener('click', () => {
    mdInput.value = '';
    update();
  });

  // Initial render
  update();
</script>
