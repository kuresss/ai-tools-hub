---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Cron Expression Generator"
  description="Build cron expressions visually with our free cron generator. See next execution times, use presets, and get human-readable descriptions."
>
  <div id="cron-app">
    <div class="space-y-6">
      <!-- Presets -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">Quick Presets</label>
        <div class="flex flex-wrap gap-2">
          <button class="cron-preset bg-gray-100 text-gray-700 px-3 py-1.5 rounded-lg text-sm hover:bg-indigo-100 hover:text-indigo-700 transition-colors" data-cron="* * * * *">Every minute</button>
          <button class="cron-preset bg-gray-100 text-gray-700 px-3 py-1.5 rounded-lg text-sm hover:bg-indigo-100 hover:text-indigo-700 transition-colors" data-cron="0 * * * *">Every hour</button>
          <button class="cron-preset bg-gray-100 text-gray-700 px-3 py-1.5 rounded-lg text-sm hover:bg-indigo-100 hover:text-indigo-700 transition-colors" data-cron="0 0 * * *">Every day at midnight</button>
          <button class="cron-preset bg-gray-100 text-gray-700 px-3 py-1.5 rounded-lg text-sm hover:bg-indigo-100 hover:text-indigo-700 transition-colors" data-cron="0 9 * * 1">Every Monday 9AM</button>
          <button class="cron-preset bg-gray-100 text-gray-700 px-3 py-1.5 rounded-lg text-sm hover:bg-indigo-100 hover:text-indigo-700 transition-colors" data-cron="0 0 1 * *">1st of every month</button>
          <button class="cron-preset bg-gray-100 text-gray-700 px-3 py-1.5 rounded-lg text-sm hover:bg-indigo-100 hover:text-indigo-700 transition-colors" data-cron="0 */6 * * *">Every 6 hours</button>
          <button class="cron-preset bg-gray-100 text-gray-700 px-3 py-1.5 rounded-lg text-sm hover:bg-indigo-100 hover:text-indigo-700 transition-colors" data-cron="*/5 * * * *">Every 5 minutes</button>
          <button class="cron-preset bg-gray-100 text-gray-700 px-3 py-1.5 rounded-lg text-sm hover:bg-indigo-100 hover:text-indigo-700 transition-colors" data-cron="0 9 * * 1-5">Weekdays at 9AM</button>
        </div>
      </div>

      <!-- Visual builder -->
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
        <div>
          <label for="cron-min" class="block text-xs font-medium text-gray-500 mb-1">Minute (0-59)</label>
          <input type="text" id="cron-min" value="*" class="w-full border border-gray-300 rounded-lg p-2 text-center font-mono text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div>
          <label for="cron-hour" class="block text-xs font-medium text-gray-500 mb-1">Hour (0-23)</label>
          <input type="text" id="cron-hour" value="*" class="w-full border border-gray-300 rounded-lg p-2 text-center font-mono text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div>
          <label for="cron-dom" class="block text-xs font-medium text-gray-500 mb-1">Day of Month (1-31)</label>
          <input type="text" id="cron-dom" value="*" class="w-full border border-gray-300 rounded-lg p-2 text-center font-mono text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div>
          <label for="cron-month" class="block text-xs font-medium text-gray-500 mb-1">Month (1-12)</label>
          <input type="text" id="cron-month" value="*" class="w-full border border-gray-300 rounded-lg p-2 text-center font-mono text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div>
          <label for="cron-dow" class="block text-xs font-medium text-gray-500 mb-1">Day of Week (0-6)</label>
          <input type="text" id="cron-dow" value="*" class="w-full border border-gray-300 rounded-lg p-2 text-center font-mono text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
      </div>

      <!-- Cron expression display -->
      <div class="bg-gray-900 text-green-400 rounded-lg p-4 text-center">
        <div class="text-xs text-gray-400 mb-1">Cron Expression</div>
        <div id="cron-expression" class="text-2xl font-mono font-bold">* * * * *</div>
        <button id="cron-copy" class="mt-2 text-xs text-gray-400 hover:text-white transition-colors">Click to copy</button>
      </div>

      <!-- Human-readable description -->
      <div class="bg-blue-50 rounded-lg p-4">
        <div class="text-sm font-medium text-blue-700 mb-1">Description</div>
        <div id="cron-description" class="text-blue-900">Every minute</div>
      </div>

      <!-- Next 5 runs -->
      <div>
        <h3 class="text-sm font-medium text-gray-700 mb-2">Next 5 Execution Times</h3>
        <div id="cron-next-runs" class="space-y-1">
        </div>
      </div>
    </div>
  </div>

  <!-- SEO Content -->
  <div class="mt-12 prose prose-sm max-w-none">
    <h2>Free Cron Expression Generator</h2>
    <p>Build cron expressions easily with our visual crontab generator. Use the interactive builder or quick presets to create cron schedules, see human-readable descriptions, and preview the next execution times. Perfect for scheduling tasks on Linux, macOS, and CI/CD systems.</p>

    <h3>Features</h3>
    <ul>
      <li><strong>Visual builder</strong> - Set minute, hour, day, month, and day-of-week fields</li>
      <li><strong>Quick presets</strong> - Common schedules like every minute, hourly, daily, weekly</li>
      <li><strong>Next 5 runs</strong> - Preview upcoming execution times</li>
      <li><strong>Human-readable</strong> - See a plain English description of your cron expression</li>
      <li><strong>One-click copy</strong> - Copy the expression to your clipboard</li>
    </ul>

    <h3>Cron Syntax Reference</h3>
    <ul>
      <li><code>*</code> - Any value</li>
      <li><code>*/n</code> - Every n intervals</li>
      <li><code>n,m</code> - Specific values</li>
      <li><code>n-m</code> - Range of values</li>
      <li>Format: <code>minute hour day-of-month month day-of-week</code></li>
    </ul>
  </div>
</ToolLayout>

<script>
  const minInput = document.getElementById('cron-min') as HTMLInputElement;
  const hourInput = document.getElementById('cron-hour') as HTMLInputElement;
  const domInput = document.getElementById('cron-dom') as HTMLInputElement;
  const monthInput = document.getElementById('cron-month') as HTMLInputElement;
  const dowInput = document.getElementById('cron-dow') as HTMLInputElement;
  const expressionEl = document.getElementById('cron-expression')!;
  const descriptionEl = document.getElementById('cron-description')!;
  const nextRunsEl = document.getElementById('cron-next-runs')!;
  const copyBtn = document.getElementById('cron-copy')!;

  const fields = [minInput, hourInput, domInput, monthInput, dowInput];
  const DOW_NAMES = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];
  const MONTH_NAMES = ['', 'January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

  function getCron(): string {
    return fields.map(f => f.value.trim() || '*').join(' ');
  }

  function describeCron(cron: string): string {
    const [min, hour, dom, month, dow] = cron.split(' ');
    const parts: string[] = [];

    // Minute
    if (min === '*') parts.push('Every minute');
    else if (min.startsWith('*/')) parts.push(`Every ${min.slice(2)} minutes`);
    else parts.push(`At minute ${min}`);

    // Hour
    if (hour !== '*') {
      if (hour.startsWith('*/')) parts.push(`every ${hour.slice(2)} hours`);
      else {
        const h = parseInt(hour);
        if (!isNaN(h)) parts.push(`at ${h.toString().padStart(2, '0')}:${min === '*' ? '00' : min.padStart(2, '0')}`);
        else parts.push(`at hour ${hour}`);
      }
    }

    // Day of month
    if (dom !== '*') {
      if (dom.startsWith('*/')) parts.push(`every ${dom.slice(2)} days`);
      else parts.push(`on day ${dom} of the month`);
    }

    // Month
    if (month !== '*') {
      if (month.startsWith('*/')) parts.push(`every ${month.slice(2)} months`);
      else {
        const m = parseInt(month);
        parts.push(`in ${MONTH_NAMES[m] || `month ${month}`}`);
      }
    }

    // Day of week
    if (dow !== '*') {
      if (dow.includes('-')) {
        const [start, end] = dow.split('-').map(Number);
        parts.push(`${DOW_NAMES[start] || start} through ${DOW_NAMES[end] || end}`);
      } else {
        const days = dow.split(',').map(d => DOW_NAMES[parseInt(d)] || d).join(', ');
        parts.push(`on ${days}`);
      }
    }

    return parts.join(', ');
  }

  function expandField(field: string, min: number, max: number): number[] {
    const results: number[] = [];
    const parts = field.split(',');
    for (const part of parts) {
      if (part === '*') {
        for (let i = min; i <= max; i++) results.push(i);
      } else if (part.startsWith('*/')) {
        const step = parseInt(part.slice(2));
        if (isNaN(step) || step <= 0) continue;
        for (let i = min; i <= max; i += step) results.push(i);
      } else if (part.includes('-')) {
        const [s, e] = part.split('-').map(Number);
        if (isNaN(s) || isNaN(e)) continue;
        for (let i = s; i <= e; i++) results.push(i);
      } else {
        const v = parseInt(part);
        if (!isNaN(v)) results.push(v);
      }
    }
    return [...new Set(results)].sort((a, b) => a - b);
  }

  function getNextRuns(cron: string, count: number): Date[] {
    const [minF, hourF, domF, monthF, dowF] = cron.split(' ');
    const mins = expandField(minF, 0, 59);
    const hours = expandField(hourF, 0, 23);
    const doms = expandField(domF, 1, 31);
    const months = expandField(monthF, 1, 12);
    const dows = expandField(dowF, 0, 6);

    if (!mins.length || !hours.length || !doms.length || !months.length || !dows.length) return [];

    const runs: Date[] = [];
    const now = new Date();
    const cursor = new Date(now.getFullYear(), now.getMonth(), now.getDate(), now.getHours(), now.getMinutes() + 1, 0, 0);
    const maxIterations = 525600; // 1 year of minutes

    for (let i = 0; i < maxIterations && runs.length < count; i++) {
      const m = cursor.getMonth() + 1;
      const d = cursor.getDate();
      const w = cursor.getDay();
      const h = cursor.getHours();
      const mi = cursor.getMinutes();

      if (months.includes(m) && doms.includes(d) && dows.includes(w) && hours.includes(h) && mins.includes(mi)) {
        runs.push(new Date(cursor));
      }

      cursor.setMinutes(cursor.getMinutes() + 1);
    }

    return runs;
  }

  function update() {
    const cron = getCron();
    expressionEl.textContent = cron;
    descriptionEl.textContent = describeCron(cron);

    const runs = getNextRuns(cron, 5);
    nextRunsEl.innerHTML = runs.length
      ? runs.map((d, i) =>
          `<div class="flex items-center gap-3 bg-gray-50 rounded-lg p-2 text-sm">
            <span class="text-gray-400 font-mono w-5">${i + 1}.</span>
            <span class="font-mono text-gray-800">${d.toLocaleString()}</span>
            <span class="text-xs text-gray-400">(${d.toUTCString()})</span>
          </div>`
        ).join('')
      : '<p class="text-sm text-red-500">Invalid cron expression or no runs found within next year.</p>';
  }

  fields.forEach(f => f.addEventListener('input', update));

  // Presets
  document.querySelectorAll('.cron-preset').forEach(btn => {
    btn.addEventListener('click', () => {
      const cron = (btn as HTMLElement).dataset.cron!;
      const parts = cron.split(' ');
      fields.forEach((f, i) => { f.value = parts[i]; });
      update();
    });
  });

  // Copy
  copyBtn.addEventListener('click', () => {
    navigator.clipboard.writeText(getCron());
    copyBtn.textContent = 'Copied!';
    setTimeout(() => { copyBtn.textContent = 'Click to copy'; }, 1500);
  });

  update();
</script>
