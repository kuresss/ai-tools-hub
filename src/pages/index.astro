---
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = [
  {
    title: 'AI Text Summarizer',
    description: 'Summarize long articles, papers, and documents instantly using AI. Runs 100% in your browser.',
    href: '/tools/summarizer',
    icon: '📝',
    badge: 'AI',
  },
  {
    title: 'AI Sentiment Analyzer',
    description: 'Analyze the sentiment and emotion of any text. Detect positive, negative, or neutral tone.',
    href: '/tools/sentiment',
    icon: '😊',
    badge: 'AI',
  },
  {
    title: 'AI Translator',
    description: 'Translate text between languages using AI. Fast, private, and completely free.',
    href: '/tools/translator',
    icon: '🌐',
    badge: 'AI',
  },
  {
    title: 'Word & Character Counter',
    description: 'Count words, characters, sentences, and paragraphs. With reading time estimation.',
    href: '/tools/word-counter',
    icon: '🔢',
    badge: 'Free',
  },
  {
    title: 'Text Case Converter',
    description: 'Convert text to UPPERCASE, lowercase, Title Case, camelCase, snake_case, and more.',
    href: '/tools/text-converter',
    icon: 'Aa',
    badge: 'Free',
  },
  {
    title: 'JSON Formatter & Validator',
    description: 'Format, beautify, minify, and validate JSON data. Essential developer tool.',
    href: '/tools/json-formatter',
    icon: '{}',
    badge: 'Free',
  },
  {
    title: 'Base64 Encoder & Decoder',
    description: 'Encode text to Base64 or decode Base64 to plain text. Great for JWT and API work.',
    href: '/tools/base64',
    icon: '#',
    badge: 'Free',
  },
  {
    title: 'Lorem Ipsum Generator',
    description: 'Generate placeholder text for designs and mockups. Paragraphs, sentences, or words.',
    href: '/tools/lorem-generator',
    icon: 'T',
    badge: 'Free',
  },
  {
    title: 'Hash Generator (MD5, SHA)',
    description: 'Generate MD5, SHA-1, SHA-256, SHA-512 hashes from text. Uses Web Crypto API.',
    href: '/tools/hash-generator',
    icon: '#',
    badge: 'Free',
  },
  {
    title: 'URL Encoder & Decoder',
    description: 'Encode or decode URLs and query strings. Supports UTF-8 characters.',
    href: '/tools/url-encoder',
    icon: '%',
    badge: 'Free',
  },
  {
    title: 'Regex Tester',
    description: 'Test regular expressions with real-time matching, highlights, and group capture.',
    href: '/tools/regex-tester',
    icon: '.*',
    badge: 'Free',
  },
  {
    title: 'Color Converter',
    description: 'Convert colors between HEX, RGB, and HSL formats with live preview.',
    href: '/tools/color-converter',
    icon: '🎨',
    badge: 'Free',
  },
  {
    title: 'Markdown Preview',
    description: 'Write Markdown and see a live preview side by side. No external libraries.',
    href: '/tools/markdown-preview',
    icon: 'M↓',
    badge: 'Free',
  },
  {
    title: 'Diff Checker',
    description: 'Compare two texts and see differences highlighted. Added lines in green, removed in red.',
    href: '/tools/diff-checker',
    icon: '±',
    badge: 'Free',
  },
  {
    title: 'QR Code Generator',
    description: 'Generate QR codes from URLs or text. Customize size and colors. Download as PNG.',
    href: '/tools/qr-generator',
    icon: '▣',
    badge: 'Free',
  },
  {
    title: 'Password Generator',
    description: 'Generate strong, random passwords with customizable length and character options.',
    href: '/tools/password-generator',
    icon: '🔑',
    badge: 'Free',
  },
  {
    title: 'Text to Speech',
    description: 'Convert text to speech using your browser. Multiple voices, speed and pitch control.',
    href: '/tools/text-to-speech',
    icon: '🔊',
    badge: 'AI',
  },
  {
    title: 'Image Compressor',
    description: 'Compress images in your browser. JPEG, PNG, WebP output. No server upload.',
    href: '/tools/image-compressor',
    icon: '🖼',
    badge: 'Free',
  },
  {
    title: 'Unix Timestamp Converter',
    description: 'Convert Unix timestamps to dates and vice versa. Supports seconds and milliseconds.',
    href: '/tools/timestamp-converter',
    icon: '⏱',
    badge: 'Free',
  },
  {
    title: 'Cron Expression Generator',
    description: 'Build cron expressions visually. See next execution times and human-readable descriptions.',
    href: '/tools/cron-generator',
    icon: '⏰',
    badge: 'Free',
  },
];
---

<BaseLayout
  title="Free AI-Powered Online Tools"
  description="Free AI tools that run entirely in your browser. Text summarizer, sentiment analyzer, translator, word counter & more. No sign-up, no API keys, 100% private."
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-indigo-600 to-purple-700 text-white py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">
        Free AI Tools That Run in Your Browser
      </h1>
      <p class="text-xl text-indigo-100 mb-8 max-w-2xl mx-auto">
        Powerful AI-powered text tools with zero cost. No sign-up. No API keys.
        Everything runs locally &mdash; your data never leaves your device.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <span class="bg-white/20 backdrop-blur px-4 py-2 rounded-full text-sm">100% Free</span>
        <span class="bg-white/20 backdrop-blur px-4 py-2 rounded-full text-sm">No Sign-up</span>
        <span class="bg-white/20 backdrop-blur px-4 py-2 rounded-full text-sm">Privacy First</span>
        <span class="bg-white/20 backdrop-blur px-4 py-2 rounded-full text-sm">Works Offline</span>
      </div>
    </div>
  </section>

  <!-- Ad Banner Placeholder -->
  <div id="ad-top" class="max-w-6xl mx-auto px-4 mt-6 text-center">
    <!-- BEGIN AADS AD UNIT 2432570 -->
    <div id="frame" style="width: 100%;margin: auto;position: relative; z-index: 99998;">
      <iframe data-aa='2432570' src='//acceptable.a-ads.com/2432570?partial=1' style='border:0px; padding:0; width:100%; height:auto; overflow:hidden; background-color: transparent;'></iframe>
    </div>
    <!-- END AADS AD UNIT 2432570 -->
  </div>

  <!-- Tools Grid -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-center mb-12">All Tools</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {tools.map((tool) => (
        <a
          href={tool.href}
          class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md hover:border-indigo-200 transition-all group"
        >
          <div class="flex items-start justify-between mb-4">
            <span class="text-3xl">{tool.icon}</span>
            <span class={`text-xs font-semibold px-2 py-1 rounded-full ${
              tool.badge === 'AI'
                ? 'bg-indigo-100 text-indigo-700'
                : 'bg-green-100 text-green-700'
            }`}>
              {tool.badge}
            </span>
          </div>
          <h3 class="text-lg font-semibold mb-2 group-hover:text-indigo-600 transition-colors">
            {tool.title}
          </h3>
          <p class="text-gray-600 text-sm">{tool.description}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Why Section -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Why AI Tools Hub?</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="text-4xl mb-4">🔒</div>
          <h3 class="font-semibold mb-2">100% Private</h3>
          <p class="text-gray-600 text-sm">All AI processing happens in your browser. Your text never leaves your device.</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-4">⚡</div>
          <h3 class="font-semibold mb-2">No API Keys</h3>
          <p class="text-gray-600 text-sm">No OpenAI key needed. No ChatGPT subscription. Just open and use.</p>
        </div>
        <div class="text-center">
          <div class="text-4xl mb-4">💰</div>
          <h3 class="font-semibold mb-2">Completely Free</h3>
          <p class="text-gray-600 text-sm">All tools are free to use with no limits. No hidden fees or premium tiers.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="max-w-4xl mx-auto px-4 py-16">
    <h2 class="text-3xl font-bold text-center mb-12">How It Works</h2>
    <div class="space-y-6">
      <div class="flex items-start gap-4">
        <span class="bg-indigo-600 text-white w-8 h-8 rounded-full flex items-center justify-center font-bold shrink-0">1</span>
        <div>
          <h3 class="font-semibold">Choose a Tool</h3>
          <p class="text-gray-600 text-sm">Select from our collection of AI and text tools above.</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <span class="bg-indigo-600 text-white w-8 h-8 rounded-full flex items-center justify-center font-bold shrink-0">2</span>
        <div>
          <h3 class="font-semibold">Paste Your Text</h3>
          <p class="text-gray-600 text-sm">Enter or paste the text you want to process.</p>
        </div>
      </div>
      <div class="flex items-start gap-4">
        <span class="bg-indigo-600 text-white w-8 h-8 rounded-full flex items-center justify-center font-bold shrink-0">3</span>
        <div>
          <h3 class="font-semibold">Get Results Instantly</h3>
          <p class="text-gray-600 text-sm">AI models load directly in your browser and process your text locally.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ for SEO -->
  <section class="bg-white py-16">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Frequently Asked Questions</h2>
      <div class="space-y-6">
        <details class="border border-gray-200 rounded-lg p-4">
          <summary class="font-semibold cursor-pointer">Is AI Tools Hub really free?</summary>
          <p class="mt-3 text-gray-600 text-sm">Yes, all tools are completely free to use. There are no hidden costs, premium tiers, or usage limits. The AI models run directly in your browser.</p>
        </details>
        <details class="border border-gray-200 rounded-lg p-4">
          <summary class="font-semibold cursor-pointer">Is my data safe?</summary>
          <p class="mt-3 text-gray-600 text-sm">Absolutely. All processing happens locally in your browser using Transformers.js. Your text is never sent to any server. You can even use the tools offline after the first load.</p>
        </details>
        <details class="border border-gray-200 rounded-lg p-4">
          <summary class="font-semibold cursor-pointer">Do I need an API key or account?</summary>
          <p class="mt-3 text-gray-600 text-sm">No. You don't need any API keys, accounts, or sign-ups. Just open the tool and start using it immediately.</p>
        </details>
        <details class="border border-gray-200 rounded-lg p-4">
          <summary class="font-semibold cursor-pointer">What AI technology do you use?</summary>
          <p class="mt-3 text-gray-600 text-sm">We use Transformers.js, which runs open-source AI models directly in your web browser using WebAssembly and WebGPU. No external API calls are made.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Ad placeholder bottom -->
  <div id="ad-bottom" class="max-w-6xl mx-auto px-4 mb-8 text-center">
    <!-- Google AdSense banner will go here -->
  </div>
</BaseLayout>
